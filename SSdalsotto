#!/bin/bash

# Cores para deixar o painel mais bonito
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color

# Função para exibir o cabeçalho do painel
display_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}     ${PURPLE}███████╗███████╗██████╗  █████╗ ██╗     ███████╗${NC}      ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}     ${PURPLE}██╔════╝██╔════╝██╔══██╗██╔══██╗██║     ██╔════╝${NC}      ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}     ${PURPLE}███████╗█████╗  ██████╔╝███████║██║     █████╗  ${NC}      ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}     ${PURPLE}╚════██║██╔══╝  ██╔══██╗██╔══██║██║     ██╔══╝  ${NC}      ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}     ${PURPLE}███████║███████╗██║  ██║██║  ██║███████╗███████╗${NC}      ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}     ${PURPLE}╚══════╝╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚══════╝${NC}      ${CYAN}║${NC}"
    echo -e "${CYAN}╠══════════════════════════════════════════════════════════╣${NC}"
    echo -e "${CYAN}║${NC}              ${GREEN}Android Security Scanner Tool${NC}                ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}                   ${YELLOW}Author: SSdalsotto${NC}                       ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}                   ${WHITE}Version: 2.0${NC}                             ${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# Função para verificar se os pacotes estão instalados
check_dependencies() {
    echo -e "${YELLOW}[*] Verificando dependências...${NC}"
    
    local deps=("git" "php" "adb")
    local missing=()
    
    for dep in "${deps[@]}"; do
        if ! command -v $dep &> /dev/null; then
            missing+=($dep)
        fi
    done
    
    if [ ${#missing[@]} -eq 0 ]; then
        echo -e "${GREEN}[✓] Todas as dependências estão instaladas!${NC}"
        return 0
    else
        echo -e "${RED}[✗] Dependências faltando: ${missing[*]}${NC}"
        return 1
    fi
}

# Função para instalar pacotes necessários
install_dependencies() {
    echo -e "${YELLOW}[*] Atualizando repositórios...${NC}"
    pkg update -y
    
    echo -e "${YELLOW}[*] Instalando dependências...${NC}"
    pkg install git php android-tools -y
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}[✓] Dependências instaladas com sucesso!${NC}"
        sleep 2
    else
        echo -e "${RED}[✗] Erro ao instalar dependências!${NC}"
        sleep 2
    fi
}

# Função para clonar o repositório e rodar o script
clone_and_run() {
    echo -e "${YELLOW}[*] Removendo repositório antigo (se houver)...${NC}"
    rm -rf SSdalsotto
    
    echo -e "${YELLOW}[*] Clonando o repositório SSdalsotto...${NC}"
    git clone https://github.com/SSdalsotto/SSdalsotto.git
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}[✓] Repositório clonado com sucesso!${NC}"
        cd SSdalsotto
        
        if [ -f "dalsottoss.php" ]; then
            echo -e "${GREEN}[✓] Script encontrado!${NC}"
            echo -e "${YELLOW}[*] Iniciando o scanner...${NC}"
            echo ""
            php dalsottoss.php
        else
            echo -e "${RED}[✗] Arquivo dalsottoss.php não encontrado!${NC}"
            echo -e "${YELLOW}[!] Verificando arquivos disponíveis:${NC}"
            ls -la
            sleep 3
        fi
    else
        echo -e "${RED}[✗] Erro ao clonar o repositório!${NC}"
        sleep 2
    fi
}

# Função para exibir status do sistema
show_status() {
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}              ${WHITE}STATUS DO SISTEMA${NC}                           ${CYAN}║${NC}"
    echo -e "${CYAN}╠══════════════════════════════════════════════════════════╣${NC}"
    
    # Verificar git
    if command -v git &> /dev/null; then
        echo -e "${CYAN}║${NC} Git: ${GREEN}✓ Instalado${NC}                                     ${CYAN}║${NC}"
    else
        echo -e "${CYAN}║${NC} Git: ${RED}✗ Não instalado${NC}                                 ${CYAN}║${NC}"
    fi
    
    # Verificar php
    if command -v php &> /dev/null; then
        PHP_VER=$(php -v 2>/dev/null | head -n 1 | cut -d' ' -f2)
        echo -e "${CYAN}║${NC} PHP: ${GREEN}✓ Instalado${NC} (v$PHP_VER)                         ${CYAN}║${NC}"
    else
        echo -e "${CYAN}║${NC} PHP: ${RED}✗ Não instalado${NC}                                 ${CYAN}║${NC}"
    fi
    
    # Verificar adb
    if command -v adb &> /dev/null; then
        echo -e "${CYAN}║${NC} ADB: ${GREEN}✓ Instalado${NC}                                     ${CYAN}║${NC}"
    else
        echo -e "${CYAN}║${NC} ADB: ${RED}✗ Não instalado${NC}                                 ${CYAN}║${NC}"
    fi
    
    # Verificar repositório
    if [ -d "SSdalsotto" ]; then
        echo -e "${CYAN}║${NC} Repositório: ${GREEN}✓ Existe${NC}                                 ${CYAN}║${NC}"
    else
        echo -e "${CYAN}║${NC} Repositório: ${RED}✗ Não clonado${NC}                             ${CYAN}║${NC}"
    fi
    
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# Função para carregar animação de loading
loading_animation() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    while [ "$(ps a | awk '{print $1}' | grep $pid)" ]; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

# Função principal do menu
menu() {
    while true; do
        display_header
        echo -e "${WHITE}┌──────────────────────────────────────────────────────────┐${NC}"
        echo -e "${WHITE}│${NC}                     ${GREEN}MENU PRINCIPAL${NC}                        ${WHITE}│${NC}"
        echo -e "${WHITE}├──────────────────────────────────────────────────────────┤${NC}"
        echo -e "${WHITE}│${NC}                                                          ${WHITE}│${NC}"
        echo -e "${WHITE}│${NC}  ${CYAN}[1]${NC} → ${GREEN}Verificar/Instalar dependências${NC}                 ${WHITE}│${NC}"
        echo -e "${WHITE}│${NC}  ${CYAN}[2]${NC} → ${GREEN}Executar scanner completo${NC}                       ${WHITE}│${NC}"
        echo -e "${WHITE}│${NC}  ${CYAN}[3]${NC} → ${YELLOW}Ver status do sistema${NC}                         ${WHITE}│${NC}"
        echo -e "${WHITE}│${NC}  ${CYAN}[4]${NC} → ${RED}Sair${NC}                                            ${WHITE}│${NC}"
        echo -e "${WHITE}│${NC}                                                          ${WHITE}│${NC}"
        echo -e "${WHITE}└──────────────────────────────────────────────────────────┘${NC}"
        echo ""
        read -p $'\e[1;37m┌─[\e[1;32mSSdalsotto@Scanner\e[1;37m]\n└──╼ \$ \e[0m' option
        
        case $option in
            1)
                echo ""
                if check_dependencies; then
                    echo -e "${YELLOW}[!] Todas as dependências já estão instaladas!${NC}"
                    echo -e "${YELLOW}[?] Deseja reinstalar? (s/n): ${NC}"
                    read -r answer
                    if [[ $answer == "s" || $answer == "S" ]]; then
                        install_dependencies
                    fi
                else
                    echo -e "${YELLOW}[!] Algumas dependências estão faltando.${NC}"
                    echo -e "${YELLOW}[?] Deseja instalá-las agora? (s/n): ${NC}"
                    read -r answer
                    if [[ $answer == "s" || $answer == "S" ]]; then
                        install_dependencies
                    fi
                fi
                echo -e "${YELLOW}Pressione ENTER para continuar...${NC}"
                read
                ;;
            2)
                echo ""
                if check_dependencies; then
                    clone_and_run
                else
                    echo -e "${RED}[✗] Dependências não satisfeitas!${NC}"
                    echo -e "${YELLOW}[!] Por favor, instale as dependências primeiro (Opção 1).${NC}"
                    sleep 3
                fi
                echo -e "${YELLOW}Pressione ENTER para continuar...${NC}"
                read
                ;;
            3)
                echo ""
                show_status
                echo -e "${YELLOW}Pressione ENTER para continuar...${NC}"
                read
                ;;
            4)
                echo ""
                echo -e "${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
                echo -e "${GREEN}║${NC}                                                          ${GREEN}║${NC}"
                echo -e "${GREEN}║${NC}        ${WHITE}Obrigado por usar o SSdalsotto Scanner!${NC}         ${GREEN}║${NC}"
                echo -e "${GREEN}║${NC}                   ${YELLOW}Até logo!${NC}                           ${GREEN}║${NC}"
                echo -e "${GREEN}║${NC}                                                          ${GREEN}║${NC}"
                echo -e "${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
                echo ""
                exit 0
                ;;
            *)
                echo -e "${RED}[✗] Opção inválida! Tente novamente.${NC}"
                sleep 2
                ;;
        esac
    done
}

# Verificar se está rodando no Termux
if [[ ! -d /data/data/com.termux ]]; then
    echo -e "${RED}[!] Este script foi desenvolvido para o Termux!${NC}"
    echo -e "${YELLOW}[!] Execute apenas no ambiente Termux.${NC}"
    exit 1
fi

# Executar o menu principal
menu
