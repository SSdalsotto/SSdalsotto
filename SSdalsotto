    $devices = adb('adb devices');
    if (empty($devices) || strpos($devices, 'device') === false || strpos($devices, 'unauthorized') !== false) {
        erro("Nenhum dispositivo detectado ou sem autorização!");
        return false;
    }

    $check = adb('adb shell "ls /sdcard"');
